# yamllint config for botworkz/geese.
#
# House style: list items sit flush with their parent key, not indented
# one extra level (Kubernetes/Ansible style):
#
#     updates:
#     - package-ecosystem: docker
#
# rather than the more common:
#
#     updates:
#       - package-ecosystem: docker
#
# This matches the majority of the YAML in this repo (envoy config,
# botspace payload manifests, dependabot, goss specs) and gets enforced
# by `indentation.indent-sequences: false`.
#
# Quirks:
#  * `truthy.check-keys: false` -- otherwise yamllint flags GitHub
#    Actions' `on:` trigger key as a YAML 1.1 truthy literal (`on`
#    is one of the 22 ways to spell `true` in 1.1).
#  * `document-start: disable` -- a few files lead with comments and
#    no `---`; not worth churning every YAML in the tree over.
#  * `line-length.max: 120` -- envoy config and goss specs have a lot
#    of URL/regex lines that don't usefully wrap. Keeps the bar above
#    most of them while still catching genuinely runaway lines.

extends: default

rules:
  indentation:
    spaces: 2
    indent-sequences: false
    check-multi-line-strings: false
  truthy:
    check-keys: false
  document-start: disable
  line-length:
    max: 120
